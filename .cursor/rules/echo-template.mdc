    With("user_id", 123, "attempted_at", time.Now())

slog.ErrorContext(ctx, "业务错误", "error", appErr)
// 输出：
// {
//   "time": "2024-01-01T12:00:00Z",
//   "level": "ERROR", 
//   "msg": "业务错误",
//   "request_id": "req-123",
//   "error": {
//     "code": 404,
//     "message": "用户不存在",
//     "user_id": 123,
//     "attempted_at": "2024-01-01T12:00:00Z"
//   }
// }
```

#### 错误处理器中的日志模式

**业务错误日志**：
```go
func logAppError(logger *slog.Logger, err *errors.AppError, c echo.Context) {
    logger.ErrorContext(c.Request().Context(),
        "Business error occurred",
        "error", err,                    // AppError 自动展开
        "path", c.Request().URL.Path,
        "method", c.Request().Method,
        "user_agent", c.Request().UserAgent(),
        "remote_addr", c.RealIP(),
    )
}
```

**HTTP 错误日志**：
```go
func logHTTPError(logger *slog.Logger, err *echo.HTTPError, c echo.Context) {
    logger.WarnContext(c.Request().Context(),
        "HTTP error occurred",
        "http_status", err.Code,
        "message", err.Message,
        "path", c.Request().URL.Path,
        "method", c.Request().Method,
        "user_agent", c.Request().UserAgent(),
        "remote_addr", c.RealIP(),
    )
}
```

