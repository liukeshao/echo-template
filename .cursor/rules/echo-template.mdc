**参数验证模式**：
```go
func (h *Handler) CreateResource(c echo.Context) error {
    var req struct {
        Name string `json:"name" validate:"required"`
        Age  int    `json:"age" validate:"min=0,max=120"`
    }
    
    if err := c.Bind(&req); err != nil {
        return errors.BadRequestError("请求参数格式错误").
            With("error", err.Error())
    }
    
    // 手动验证或使用验证库
    if req.Name == "" {
        return ValidationError("验证失败", []ErrorDetail{
            {Field: "name", Message: "名称不能为空", Code: "REQUIRED"},
        }).JSON(c)
    }
    
    // 继续处理...
}
```

**数据库操作模式**：
```go
func (h *Handler) UpdateResource(c echo.Context) error {
    ctx := c.Request().Context()
    id := c.Param("id")
    
    // 开启事务
    tx, err := h.orm.Tx(ctx)
    if err != nil {
        return errors.DatabaseError("开启事务失败").Wrap(err)
    }
    defer tx.Rollback()
    
    // 检查资源是否存在
    resource, err := tx.Resource.Query().
        Where(resource.ID(id)).
        Only(ctx)
    if err != nil {
        if ent.IsNotFound(err) {
            return errors.NotFoundError("资源不存在").
                With("resource_id", id)
        }
        return errors.DatabaseError("查询资源失败").
            Wrap(err).
            With("resource_id", id)
    }
    
    // 更新操作
    updatedResource, err := tx.Resource.UpdateOne(resource).
        SetName("new name").
        Save(ctx)
    if err != nil {
        return errors.DatabaseError("更新资源失败").
            Wrap(err).
            With("resource_id", id)
    }
    
    // 提交事务
    if err := tx.Commit(); err != nil {
        return errors.DatabaseError("提交事务失败").
            Wrap(err).
            With("resource_id", id)
    }
    
    return Success(updatedResource).JSON(c)
}
```

#### 自动注册机制

项目使用 `init()` 函数自动注册 Handler：

1. **每个 Handler 文件都包含**：
```go
func init() {
    Register(new(YourHandler))
}
```

2. **路由器自动加载所有注册的 Handler**：
```go
// BuildRouter 会自动初始化并注册所有 Handler
for _, h := range GetHandlers() {
    if err := h.Init(c); err != nil {
        return err
    }
    h.Routes(g)
}
```

3. **无需手动管理 Handler 列表**，只要导入包即可自动注册

