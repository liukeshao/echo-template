# Echo Template 项目 Cursor 规则

## 项目概述
这是一个基于 Go 的高性能 Web 应用模板，使用以下技术栈：
- **Web 框架**: Echo v4 - 高性能、可扩展、极简的 Go Web 框架
- **ORM**: Ent - 简单而强大的实体框架，用于数据建模和查询
- **数据库**: SQLite - 轻量级、高可靠性的嵌入式数据库
- **配置管理**: Viper - 灵活的配置管理库
- **测试**: Testify - Go 测试断言库

## 代码规范

### 1. 项目结构规范
```
/
├── cmd/           # 应用程序入口点
├── pkg/           # 核心业务逻辑
│   ├── handlers/  # HTTP 路由处理器
│   ├── services/  # 业务服务层
│   ├── middleware/ # 中间件
│   ├── context/   # 上下文处理
│   ├── errors/    # 错误处理
│   ├── log/       # 日志系统
│   └── tests/     # 测试辅助工具
├── config/        # 配置文件和结构
└──ent/           # Ent ORM 生成代码和 schema
```

### 2. Handler 开发规范

#### Handler 接口
所有 Handler 必须实现以下接口：

```go
type Handler interface {
    // Routes 允许自注册 HTTP 路由到路由器
    Routes(g *echo.Group)
    
    // Init 提供服务容器进行初始化
    Init(*services.Container) error
}
```

#### Handler 开发模式

**1. 定义 Handler 结构体**：
```go
// UserHandler 用户相关处理器
type UserHandler struct {
    orm    *ent.Client    // ORM 客户端
    config *config.Config // 配置
    // 其他需要的服务依赖
}
```

**2. 实现 Init 方法（依赖注入）**：
```go
func (h *UserHandler) Init(c *services.Container) error {
    h.orm = c.ORM
    h.config = c.Config
    return nil
}
```

**3. 使用 init 函数注册 Handler**：
```go
func init() {
    Register(new(UserHandler))
}
```

**4. 实现 Routes 方法（路由定义）**：
```go
func (h *UserHandler) Routes(g *echo.Group) {
    // API 路由组
    api := g.Group("/api/v1/users")
    
    // RESTful 路由
    api.GET("", h.GetUsers)           // GET /api/v1/users
    api.POST("", h.CreateUser)        // POST /api/v1/users
    api.GET("/:id", h.GetUser)        // GET /api/v1/users/:id
    api.PUT("/:id", h.UpdateUser)     // PUT /api/v1/users/:id
    api.DELETE("/:id", h.DeleteUser)  // DELETE /api/v1/users/:id
}
```

**5. 实现具体的路由处理方法**：
```go
func (h *UserHandler) GetUser(c echo.Context) error {
    ctx := c.Request().Context()
    userID := c.Param("id")
    
    // 记录请求开始
    slog.InfoContext(ctx, "开始查询用户", "user_id", userID)
    
    // 业务逻辑
    user, err := h.orm.User.Query().
        Where(user.ID(userID)).
        Only(ctx)
    if err != nil {
        // 记录错误
        slog.ErrorContext(ctx, "查询用户失败", 
            "error", err,
            "user_id", userID,
        )
        
        if ent.IsNotFound(err) {
            return errors.NotFoundError("用户不存在").
                With("user_id", userID)
        }
        return errors.DatabaseError("查询用户失败").
            Wrap(err).
            With("user_id", userID)
    }
    
    // 记录成功
    slog.InfoContext(ctx, "查询用户成功", 
        "user_id", userID,
        "username", user.Name,
    )
    
    // 返回成功响应
    return Success(user).JSON(c)
}
```

#### 完整 Handler 示例

```go
package handlers

import (
    "log/slog"
    "strconv"
    
    "github.com/labstack/echo/v4"
    "github.com/liukeshao/echo-template/ent"
    "github.com/liukeshao/echo-template/ent/user"
    "github.com/liukeshao/echo-template/pkg/errors"
    "github.com/liukeshao/echo-template/pkg/services"
)

// UserHandler 用户处理器
type UserHandler struct {
    orm *ent.Client
}

// 自动注册
func init() {
    Register(new(UserHandler))
}

// Init 依赖注入
func (h *UserHandler) Init(c *services.Container) error {
    h.orm = c.ORM
    return nil
}

// Routes 路由定义
func (h *UserHandler) Routes(g *echo.Group) {
    api := g.Group("/api/v1/users")
    
    api.GET("", h.GetUsers)
    api.POST("", h.CreateUser)
    api.GET("/:id", h.GetUser)
    api.PUT("/:id", h.UpdateUser)
    api.DELETE("/:id", h.DeleteUser)
}

// GetUsers 获取用户列表
func (h *UserHandler) GetUsers(c echo.Context) error {
    ctx := c.Request().Context()
    
    // 解析查询参数
    limit, _ := strconv.Atoi(c.QueryParam("limit"))
    if limit <= 0 {
        limit = 10
    }
    
    offset, _ := strconv.Atoi(c.QueryParam("offset"))
    if offset < 0 {
        offset = 0
    }
    
    slog.InfoContext(ctx, "查询用户列表", 
        "limit", limit, 
        "offset", offset,
    )
    
    // 查询数据
    users, err := h.orm.User.Query().
        Limit(limit).
        Offset(offset).
        All(ctx)
    if err != nil {
        slog.ErrorContext(ctx, "查询用户列表失败", "error", err)
        return errors.DatabaseError("查询用户列表失败").Wrap(err)
    }
    
    // 查询总数
    total, err := h.orm.User.Query().Count(ctx)
    if err != nil {
        slog.ErrorContext(ctx, "查询用户总数失败", "error", err)
        return errors.DatabaseError("查询用户总数失败").Wrap(err)
    }
    
    slog.InfoContext(ctx, "查询用户列表成功", 
        "count", len(users),
        "total", total,
    )
    
    // 构建响应
    result := map[string]interface{}{
        "users": users,
        "pagination": map[string]interface{}{
            "limit":  limit,
            "offset": offset,
            "total":  total,
        },
    }
    
    return Success(result).JSON(c)
}

// CreateUser 创建用户
func (h *UserHandler) CreateUser(c echo.Context) error {
    ctx := c.Request().Context()
    
    // 解析请求体
    var req struct {
        Name  string `json:"name" validate:"required"`
        Email string `json:"email" validate:"required,email"`
    }
    
    if err := c.Bind(&req); err != nil {
        return errors.BadRequestError("请求参数无效").
            With("error", err.Error())
    }
    
    // 验证请求参数
    if req.Name == "" {
        return ValidationError("验证失败", []ErrorDetail{
            {Field: "name", Message: "用户名不能为空", Code: "REQUIRED"},
        }).JSON(c)
    }
    
    if req.Email == "" {
        return ValidationError("验证失败", []ErrorDetail{
            {Field: "email", Message: "邮箱不能为空", Code: "REQUIRED"},
        }).JSON(c)
    }
    
    slog.InfoContext(ctx, "开始创建用户", 
        "name", req.Name,
        "email", req.Email,
    )
    
    // 创建用户
    user, err := h.orm.User.Create().
        SetName(req.Name).
        SetEmail(req.Email).
        Save(ctx)
    if err != nil {
        slog.ErrorContext(ctx, "创建用户失败", 
            "error", err,
            "name", req.Name,
            "email", req.Email,
        )
        
        if ent.IsConstraintError(err) {
            return errors.ConflictError("用户邮箱已存在").
                With("email", req.Email)
        }
        
        return errors.DatabaseError("创建用户失败").
            Wrap(err).
            With("name", req.Name, "email", req.Email)
    }
    
    slog.InfoContext(ctx, "创建用户成功", 
        "user_id", user.ID,
        "name", user.Name,
        "email", user.Email,
    )
    
    return Success(user).JSON(c)
}
```

